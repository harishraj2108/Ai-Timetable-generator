<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TimeTable AI — Sign In</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/login-page.css">
</head>
<body>

<% if (error) { %>
  <div class="toast toast--error">
    <i class="fas fa-circle-xmark"></i>
    <span><%= error %></span>
  </div>
<% } %>
<% if (success) { %>
  <div class="toast toast--success">
    <i class="fas fa-circle-check"></i>
    <span><%= success %></span>
  </div>
<% } %>

<div class="bg-grid"></div>
<div class="bg-glow"></div>

<main class="shell">

  <!-- Left Panel -->
  <aside class="brand-panel">
    <div class="brand-panel__inner">
      <div class="brand-logo">
        <span class="brand-logo__icon">⌘</span>
        <span class="brand-logo__name">TimeTable <em>AI</em></span>
      </div>
      <div class="brand-copy">
        <h1 class="brand-copy__headline">Intelligent<br>Scheduling,<br><em>Redefined.</em></h1>
        <p class="brand-copy__sub">Generate optimised academic timetables in seconds — powered by AI.</p>
      </div>
      <div class="brand-stats">
        <div class="stat"><span class="stat__num">99%</span><span class="stat__label">Conflict-Free</span></div>
        <div class="stat"><span class="stat__num">&lt;10s</span><span class="stat__label">Generation</span></div>
        <div class="stat"><span class="stat__num">PDF</span><span class="stat__label">Export Ready</span></div>
      </div>
    </div>
  </aside>

  <!-- Right Panel -->
  <section class="form-panel">
    <div class="form-card">
      <header class="form-card__header">
        <p class="form-card__eyebrow">Welcome back</p>
        <h2 class="form-card__title">Sign in</h2>
      </header>

      <form action="/" method="POST" autocomplete="off" class="auth-form">

        <div class="field">
          <label class="field__label" for="email">Email address</label>
          <div class="field__wrap">
            <i class="fas fa-envelope field__icon"></i>
            <input class="field__input" type="text" id="email" name="email" placeholder="you@university.edu" autocomplete="off" required>
          </div>
        </div>

        <div class="field">
          <label class="field__label" for="password">Password</label>
          <div class="field__wrap">
            <i class="fas fa-lock field__icon"></i>
            <input class="field__input" type="password" id="password" name="password" autocomplete="new-password" placeholder="••••••••" required>
            <button type="button" class="field__toggle" onclick="togglePassword()" tabindex="-1">
              <i class="fas fa-eye" id="eye-icon"></i>
            </button>
          </div>
        </div>

        <div class="form-meta">
          <label class="checkbox-label">
            <input type="checkbox" class="checkbox-label__input"> Remember me
          </label>
          <a href="#" class="link-muted">Forgot password?</a>
        </div>

        <button type="submit" class="btn-primary">
          <span>Continue</span>
          <i class="fas fa-arrow-right"></i>
        </button>

      </form>

      <p class="form-card__footer">New here? <a href="/register" class="link-accent">Create an account</a></p>
    </div>
  </section>

</main>

<script>
function togglePassword() {
  const pwd = document.getElementById("password");
  const icon = document.getElementById("eye-icon");
  if (pwd.type === "password") {
    pwd.type = "text";
    icon.classList.replace("fa-eye", "fa-eye-slash");
  } else {
    pwd.type = "password";
    icon.classList.replace("fa-eye-slash", "fa-eye");
  }
}
window.addEventListener("pageshow", () => document.querySelector("form").reset());
</script>
</body>
</html>
